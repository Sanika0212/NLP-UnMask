/* ═══════════════════════════════════════════════════════════════════════════
   UnMask — Clean Medical Blue
   High contrast · proper cards · clinical blue/teal
   ═══════════════════════════════════════════════════════════════════════════ */

/* Font loaded via unmask.js preconnect links */

:root {
  --bg:        #060d18;
  --card:      #0d1e33;
  --card2:     #112843;
  --border:    #1c3553;
  --border-hi: #2d5080;

  --blue:      #3b82f6;
  --blue-dim:  #1d4ed8;
  --teal:      #2dd4bf;
  --teal-dim:  #0f766e;
  --green:     #22c55e;
  --amber:     #fbbf24;
  --rose:      #f43f5e;

  --text:      #ffffff;
  --text-2:    #b8d0ec;
  --text-3:    #5a7a99;

  --r:  10px;
  --r2: 6px;
}

/* ── Base ─────────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

html, body, #root {
  background: var(--bg) !important;
  color: var(--text) !important;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  font-size: 16px !important;
  line-height: 1.7 !important;
  -webkit-font-smoothing: antialiased !important;
}

/* ── Header ───────────────────────────────────────────────────────────────── */
header, [class*="header"] {
  background: var(--card) !important;
  border-bottom: 1px solid var(--border) !important;
  box-shadow: 0 1px 0 var(--border) !important;
}
header [class*="name"], header h6 {
  font-weight: 600 !important;
  letter-spacing: 0.02em !important;
  color: var(--text) !important;
  font-family: 'Inter', sans-serif !important;
}

/* ── Sidebar ──────────────────────────────────────────────────────────────── */
aside, [class*="sidebar"] {
  background: var(--card) !important;
  border-right: 1px solid var(--border) !important;
}

/* ── Main area ────────────────────────────────────────────────────────────── */
main, [role="main"] { background: var(--bg) !important; }

/* ── ALL message wrappers — clean card ───────────────────────────────────── */
[class*="message"], [class*="Message"],
[data-testid*="message"] {
  background: var(--card) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--r) !important;
  box-shadow: none !important;
  margin-bottom: 6px !important;
  padding: 0 !important;
}

/* User message — subtle blue tint to differentiate */
[class*="user"][class*="message"],
[class*="UserMessage"],
[data-testid*="user-message"] {
  background: var(--card2) !important;
  border-color: var(--blue-dim) !important;
}

/* ── Text ─────────────────────────────────────────────────────────────────── */
/* Force readable font size everywhere MUI would shrink it */
body p, body li, body td, body th,
body [class*="message"] p,
body [class*="Message"] p,
body [class*="content"] p {
  font-size: 1rem !important;
  line-height: 1.75 !important;
  color: var(--text) !important;
}

p, li, td, th {
  color: var(--text) !important;
  font-size: 1rem !important;
  line-height: 1.75 !important;
}
h1, h2, h3, h4 {
  font-family: 'Inter', sans-serif !important;
  font-weight: 600 !important;
  color: var(--text) !important;
  line-height: 1.3 !important;
  margin: 0.8rem 0 0.3rem !important;
}
h1 { font-size: 1.5rem !important; }
h2 { font-size: 1.2rem !important; }
h3 { font-size: 1.05rem !important; color: var(--text-2) !important; font-weight: 500 !important; }

strong, b { color: var(--text) !important; font-weight: 600 !important; }
em { color: var(--text-2) !important; }
del { color: var(--text-3) !important; }

/* ── Blockquote ───────────────────────────────────────────────────────────── */
blockquote {
  border-left: 3px solid var(--teal) !important;
  background: rgba(20,184,166,0.08) !important;
  border-radius: 0 var(--r2) var(--r2) 0 !important;
  padding: 0.5rem 0.9rem !important;
  margin: 0.6rem 0 !important;
  color: var(--text) !important;
}
blockquote p { font-size: 0.92rem !important; color: var(--text) !important; }

/* ── Code ─────────────────────────────────────────────────────────────────── */
code {
  font-family: 'JetBrains Mono', 'Courier New', monospace !important;
  font-size: 0.82em !important;
  color: var(--teal) !important;
  background: rgba(20,184,166,0.1) !important;
  border-radius: 3px !important;
  padding: 0.1em 0.35em !important;
}
pre {
  background: #080f1a !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--r2) !important;
  padding: 0.85rem 1rem !important;
  overflow-x: auto !important;
}
pre code {
  background: transparent !important;
  padding: 0 !important;
  color: var(--text-2) !important;
  font-size: 0.88rem !important;
}

hr {
  border: none !important;
  border-top: 1px solid var(--border) !important;
  margin: 0.7rem 0 !important;
}

/* ── Author label ─────────────────────────────────────────────────────────── */
[class*="author"], [class*="Author"] {
  font-family: 'JetBrains Mono', monospace !important;
  font-size: 0.68rem !important;
  letter-spacing: 0.1em !important;
  text-transform: uppercase !important;
  color: var(--text-3) !important;
}

/* ── Steps (Supervisor) ───────────────────────────────────────────────────── */
[class*="step"], [class*="Step"] {
  background: var(--card) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--r2) !important;
  box-shadow: none !important;
  font-size: 0.78rem !important;
  margin-bottom: 4px !important;
}
[class*="step"] * { font-family: 'JetBrains Mono', monospace !important; color: var(--text-2) !important; font-size: 0.78rem !important; }

/* ── Action buttons ───────────────────────────────────────────────────────── */
button[class*="action"], [class*="Action"] button,
[class*="action-button"], [class*="ActionButton"] {
  font-family: 'Inter', sans-serif !important;
  font-size: 0.95rem !important;
  font-weight: 500 !important;
  background: var(--card2) !important;
  border: 1px solid var(--border-hi) !important;
  color: var(--text) !important;
  border-radius: var(--r2) !important;
  padding: 0.45rem 1rem !important;
  cursor: pointer !important;
  transition: all 0.15s ease !important;
  margin: 3px !important;
}
button[class*="action"]:hover, [class*="Action"] button:hover,
[class*="action-button"]:hover {
  background: var(--blue) !important;
  border-color: var(--blue) !important;
  color: #fff !important;
  box-shadow: 0 0 0 3px rgba(59,130,246,0.2) !important;
}

/* ── Send button ──────────────────────────────────────────────────────────── */
button[class*="send"], [aria-label*="send"], [data-testid*="send"] {
  background: var(--blue) !important;
  border: none !important;
  border-radius: var(--r2) !important;
  transition: background 0.15s !important;
}
button[class*="send"]:hover { background: var(--teal) !important; }

/* ── Textarea ─────────────────────────────────────────────────────────────── */
textarea, [class*="composer"] {
  background: var(--card) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--r) !important;
  color: var(--text) !important;
  font-family: 'Inter', sans-serif !important;
  font-size: 1rem !important;
  caret-color: var(--blue) !important;
  transition: border-color 0.15s !important;
}
textarea:focus { border-color: var(--blue-dim) !important; outline: none !important; }
textarea::placeholder { color: var(--text-3) !important; }

/* ── Bottom bar ───────────────────────────────────────────────────────────── */
[class*="footer"], [class*="Footer"],
[class*="input-container"], [class*="InputContainer"] {
  background: var(--bg) !important;
  border-top: 1px solid var(--border) !important;
}
[class*="footer"] p, [class*="footer"] span, [class*="disclaimer"] {
  font-size: 0.68rem !important;
  color: var(--text-3) !important;
  opacity: 0.5 !important;
}

/* ── Images ───────────────────────────────────────────────────────────────── */
img {
  border-radius: var(--r) !important;
  border: 1px solid var(--border) !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.4) !important;
  max-width: 100% !important;
}

/* ── Scrollbar ────────────────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border-hi); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--blue-dim); }

::selection { background: rgba(59,130,246,0.3) !important; }

/* ── Dialog ───────────────────────────────────────────────────────────────── */
[role="dialog"] {
  background: var(--card) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: var(--r) !important;
}
